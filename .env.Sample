HOST_PORT = 34749

# Server bind address
BIND_ADDR=0.0.0.0:8000

# Directory containing model folders
MODELS_DIR=AI_Models

# Default model name when request does not specify one
DEFAULT_MODEL=

# Model unload TTL in seconds (2 hours default)
MODEL_TTL_SECONDS=7200

# Logging level
RUST_LOG=info

# Backend selection
# true: prefer GPU backend when available
# false: force CPU
USE_GPU=true

# Set to true only when GPU backend is actually available in the runtime
GPU_AVAILABLE=true
